generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  password     String
  phone        String?
  city         String?
  blood_group  String?
  role         String   @default("receiver")
  created_at   DateTime @default(now())
}